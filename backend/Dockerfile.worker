# Celery Worker Dockerfile
# 专门用于构建 Celery Worker 镜像

# ==========================================
# 基础镜像
# ==========================================
FROM python:3.11-slim as base

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    POETRY_VERSION=1.7.1 \
    POETRY_HOME=/opt/poetry \
    POETRY_VIRTUALENVS_IN_PROJECT=true \
    POETRY_NO_INTERACTION=1

# 安装系统依赖（Worker 需要更多 ML 相关依赖）
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    gcc \
    g++ \
    curl \
    # 简历解析相关依赖
    tesseract-ocr \
    tesseract-ocr-chi-sim \
    tesseract-ocr-chi-tra \
    poppler-utils \
    libmagic1 \
    # 机器学习依赖
    libgomp1 \
    libblas-dev \
    liblapack-dev \
    # 其他工具
    wget \
    && rm -rf /var/lib/apt/lists/*

# 安装 Poetry
RUN curl -sSL https://install.python-poetry.org | python3 - && \
    ln -s /opt/poetry/bin/poetry /usr/local/bin/poetry

# 设置工作目录
WORKDIR /app

# ==========================================
# 构建阶段
# ==========================================
FROM base as builder

# 复制依赖文件
COPY pyproject.toml poetry.lock* ./

# 安装所有依赖（Worker 需要 ML 库）
RUN poetry install --no-root

# 复制应用代码
COPY . .

# 安装应用
RUN poetry install --only-root

# 预下载模型（可选，加速启动）
# RUN poetry run python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-large-zh')"

# ==========================================
# 生产阶段
# ==========================================
FROM python:3.11-slim as production

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1 \
    APP_HOME=/app \
    C_FORCE_ROOT=true

# 安装运行时依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    # 简历解析相关运行时依赖
    tesseract-ocr \
    tesseract-ocr-chi-sim \
    tesseract-ocr-chi-tra \
    poppler-utils \
    libmagic1 \
    # 机器学习运行时依赖
    libgomp1 \
    libblas3 \
    liblapack3 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 创建非 root 用户（Celery 不建议以 root 运行，但 Docker 中需要处理）
RUN groupadd -r celery && useradd -r -g celery celery

# 设置工作目录
WORKDIR ${APP_HOME}

# 从构建阶段复制虚拟环境
COPY --from=builder /app/.venv /app/.venv

# 复制应用代码
COPY --from=builder /app/app ./app
COPY --from=builder /app/pyproject.toml ./

# 设置虚拟环境路径
ENV PATH="/app/.venv/bin:$PATH"

# 创建必要的目录并设置权限
RUN mkdir -p /tmp/celery /var/log/celery /var/run/celery && \
    chown -R celery:celery /tmp/celery /var/log/celery /var/run/celery ${APP_HOME}

# 切换到非 root 用户
USER celery

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD celery -A app.tasks inspect ping || exit 1

# 默认启动命令（可被 docker-compose 覆盖）
CMD ["celery", "-A", "app.tasks", "worker", "--loglevel=info", "--concurrency=4"]
