# AgentHire 环境变量配置模板
# 复制此文件为 .env 并根据需要修改
# ⚠️ 警告：不要将包含真实密钥的 .env 文件提交到版本控制！

# ==========================================
# 基础配置
# ==========================================
ENVIRONMENT=development
VERSION=0.1.0
LOG_LEVEL=DEBUG

# ==========================================
# 数据库配置
# ==========================================
# PostgreSQL 配置
POSTGRES_DB=agenthire
POSTGRES_USER=agenthire
POSTGRES_PASSWORD=agenthire123
DATABASE_URL=postgresql://agenthire:agenthire123@db:5432/agenthire

# 数据库连接池配置（生产环境）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ==========================================
# Redis 配置
# ==========================================
REDIS_URL=redis://redis:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# ==========================================
# 对象存储配置（开发环境使用 MinIO）
# ==========================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=agenthire
MINIO_USE_SSL=false

# ==========================================
# 对象存储配置（生产环境使用 S3/OSS）
# ==========================================
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET_NAME=agenthire-prod
# S3_REGION=us-east-1
# S3_USE_SSL=true

# ==========================================
# 安全配置
# ==========================================
# JWT 配置（生产环境请使用强密钥）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码哈希
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_SALT_ROUNDS=12

# ==========================================
# AI 服务配置
# ==========================================
# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# 嵌入模型配置
EMBEDDING_MODEL=BAAI/bge-large-zh
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

# 备用嵌入模型（开源）
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_DIMENSION=384

# ==========================================
# 简历解析配置
# ==========================================
# OCR 配置
OCR_ENGINE=paddleocr
OCR_LANGUAGE=ch_sim+eng

# PDF 解析配置
PDF_EXTRACTOR=pymupdf

# 解析超时时间（秒）
RESUME_PARSE_TIMEOUT=120

# ==========================================
# 匹配引擎配置
# ==========================================
# 向量匹配阈值
MATCH_DEFAULT_THRESHOLD=0.7
MATCH_MAX_RESULTS=50

# 各维度权重
MATCH_SKILL_WEIGHT=0.4
MATCH_EXPERIENCE_WEIGHT=0.25
MATCH_LOCATION_WEIGHT=0.2
MATCH_SALARY_WEIGHT=0.15

# ==========================================
# Webhook 配置
# ==========================================
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5

# ==========================================
# 监控和日志配置
# ==========================================
# Sentry 错误追踪
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus 指标
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 日志配置
LOG_FORMAT=json
LOG_FILE=/var/log/agenthire/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# ==========================================
# 邮件配置（无需域名，使用 Resend 或 Gmail SMTP）
# ==========================================

# 启用邮件：true/false
EMAIL_ENABLED=true

# 邮件后端：resend（推荐）、smtp 或 console（测试用）
EMAIL_BACKEND=resend

# 方案1：Resend 配置（推荐，无需域名，无需 SMTP）
# 注册：https://resend.com
# 免费额度：100封/天
RESEND_API_KEY=re_HG5u1WXd_8URJEBSMsULqoUVkTj7WUNaH

# 方案2：SMTP 配置（Gmail 等）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASSWORD=your_app_password

# 发件人邮箱
# Resend 测试模式可用：onboarding@resend.dev
# 或有域名后使用：noreply@yourdomain.com
FROM_EMAIL=onboarding@resend.dev

# ==========================================
# 业务配置
# ==========================================
# 企业认证配置
ENTERPRISE_VERIFY_REQUIRED=true
ENTERPRISE_AUTO_APPROVE=false

# 计费配置
BILLING_CURRENCY=CNY
BILLING_PAY_AS_YOU_GO_RATE=0.5
BILLING_MONTHLY_BASIC=999
BILLING_MONTHLY_BASIC_QUOTA=2000
BILLING_MONTHLY_PRO=2999
BILLING_MONTHLY_PRO_QUOTA=10000

# 限流配置
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_RESUME_PARSE=10

# ==========================================
# 生产环境特定配置
# ==========================================
# API 副本数
API_REPLICAS=3
WORKER_REPLICAS=2

# Flower 监控
FLOWER_BASIC_AUTH=admin:admin
FLOWER_URL_PREFIX=/flower

# SSL 证书路径（生产环境）
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
