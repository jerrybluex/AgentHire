# AgentHire Database Environment Configuration
# Copy this file to .env and modify as needed

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agenthire
POSTGRES_USER=agenthire
POSTGRES_PASSWORD=agenthire_dev_password

# Database URL for SQLAlchemy/Alembic
DATABASE_URL=postgresql://agenthire:agenthire_dev_password@localhost:5432/agenthire

# pgAdmin Configuration
PGADMIN_EMAIL=admin@agenthire.com
PGADMIN_PASSWORD=admin123

# Vector Configuration
VECTOR_DIMENSION=384

# Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
